# Mission Control — environment template
# Copy to .env and fill in. .env is gitignored — never commit it.

# Discord
# 1. Create app at https://discord.com/developers/applications
# 2. Bot tab → Reset Token → Copy → paste here
DISCORD_BOT_TOKEN=

# Right-click your server name in Discord → Copy Server ID
DISCORD_GUILD_ID=

# Channel IDs — right-click each channel → Copy Channel ID
# (Enable Developer Mode under User Settings → Advanced if missing.)
CHAN_MISSION_CONTROL=
CHAN_APPROVALS=
CHAN_NEWSIE=
CHAN_THINKIE=
CHAN_SORTIE=
CHAN_CLAUDIE=
CHAN_COLD_EXIT_DEV=
CHAN_COLD_EXIT_DESIGN=
CHAN_COLD_EXIT_ASSETS=
CHAN_THOUGHTS=
CHAN_DREAMS=
CHAN_IDEAS=
CHAN_DAILY_DIGEST=
CHAN_WEEKLY_DIGEST=
CHAN_MEMORY=

# Active project mission-control is managing. The audits/ folder for
# every Sage / Wrenchy run lands in <MC_PROJECT_ROOT>/audits/.
# Default: parent-of-parent-of-parent of mission-control (legacy
# layout where mission-control lived inside the project at
# tools/mission-control/). After the directory extract, point this at
# the absolute path of whichever repo the team is working on.
MC_PROJECT_ROOT=C:/work/Personal/tacticalrogue

# Ollama — IPv4 explicit (Node prefers ::1 for "localhost" but Ollama
# binds 127.0.0.1 only on Windows; the mismatch shows up as
# silent "fetch failed" errors)
OLLAMA_HOST=http://127.0.0.1:11434

# Anthropic API (optional, for Newsie/Thinkie/Sortie when calling Sonnet)
# Newsie + Thinkie + Sortie posts WILL fall back to local qwen with a
# warning banner if this is unset, so you can run the whole stack on
# local-only first.
ANTHROPIC_API_KEY=

# Timezone for cron schedules (e.g. America/Los_Angeles, America/New_York)
TZ=America/Los_Angeles
