# Dependencies / build output (none today, but guard so a future
# npm / wrangler local install doesn't accidentally commit lockfiles
# or caches).
node_modules/
.wrangler/
.cache/
dist/
build/

# Local editor / tool state
.vscode/
.idea/
.claude/

# OS noise
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Env / secret files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Local test / scratch files
scratch/
tmp/

# Source-archive zips — the original asset-pack downloads (~3 GiB).
# The extracted FBX/PNG files in subfolders are what the game loads
# at runtime, those stay tracked.
Assets/*.zip
Assets/*.unitypackage

# Chrome DevTools performance traces — accumulating reference snapshots
# in the repo bloats clones. Keep one canonical trace if needed; toss
# the rest.
profiling/*.json
profiling/*.json.gz
